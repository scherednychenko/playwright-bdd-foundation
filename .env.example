# Copy to .env. All values are optional.

# Target application. Leave unset to run against the bundled demo app
# (http://localhost:3000). Set it to run the suite against a deployed app.
# BASE_URL=https://your-app.example.com

# Tag slice to generate and run.
E2E_TAGS=@smoke

# Set to false to watch the browser while tests run.
E2E_HEADLESS=true

# Set to 1 to run the full Chromium/Firefox/WebKit matrix (default: Chromium only).
# E2E_ALL_BROWSERS=1
